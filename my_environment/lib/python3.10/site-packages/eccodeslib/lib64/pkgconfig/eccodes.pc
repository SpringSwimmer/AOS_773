git_tag=5287988169775d5cbadc817b4e578f6d9c9fdd21

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include
bindir=${prefix}/bin
fmoddir=${prefix}/include

CC=/opt/rh/gcc-toolset-14/root/usr/bin/cc
CXX=/opt/rh/gcc-toolset-14/root/usr/bin/c++
FC=

libs=-Wl,-rpath,${libdir} -L${libdir} -leccodes

libs_private=-Wl,-rpath,/tmp/openjpeg/target/lib64 -L/tmp/openjpeg/target/lib64 -lopenjp2 -Wl,-rpath,${libdir} -L${libdir} -leccodes_memfs -Wl,-rpath,/tmp/eccodes/prereqs/eckitlib/lib64 -L/tmp/eccodes/prereqs/eckitlib/lib64 -leckit_geo -Wl,-rpath,/tmp/eccodes/prereqs/eckitlib/lib64 -L/tmp/eccodes/prereqs/eckitlib/lib64 -leckit_maths -Wl,-rpath,/tmp/eccodes/prereqs/eckitlib/lib64 -L/tmp/eccodes/prereqs/eckitlib/lib64 -leckit_spec -Wl,-rpath,/tmp/eccodes/prereqs/eckitlib/lib64 -L/tmp/eccodes/prereqs/eckitlib/lib64 -leckit_codec -Wl,-rpath,/tmp/eccodes/prereqs/eckitlib/lib64 -L/tmp/eccodes/prereqs/eckitlib/lib64 -leckit -lrt -ldl -lpthread -lpng -lz -l$<1:libaec::aec -lm

cflags=-I${includedir} -I/tmp/eccodes/target/eccodes/include

### Features:

HAVE_MEMFS=1
HAVE_GEOGRAPHY=1
HAVE_JPEG=1
HAVE_LIBJASPER=0
HAVE_LIBOPENJPEG=1
HAVE_ECCODES_THREADS=1
HAVE_ECCODES_OMP_THREADS=0
HAVE_NETCDF=0
HAVE_FORTRAN=0
HAVE_PNG=1
HAVE_AEC=1
HAVE_ECKIT_GEO=1

#====================================================================
Name: eccodes
Description: The ecCodes library
URL: https://confluence.ecmwf.int/display/ECC/
Version: 2.46.2
Libs: ${libs}
Libs.private: ${libs_private}
Requires: 
Requires.private: 
Cflags: ${cflags}
